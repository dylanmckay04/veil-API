# Toggle Testing — disables rate limiting and skips wait_for_db() at startup.
TESTING=1

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ouijadb
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/ouijadb

# Auth — generate via:  python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your_secret_key_here

# Redis
REDIS_URL=redis://localhost:6379
